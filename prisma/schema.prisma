generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DistanceSource {
  ROUTING_API
  MANUAL_OVERRIDE
}

model Depot {
  id        String   @id @default(cuid())
  name      String
  address   String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

model VehicleType {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  sortOrder Int         @default(0)
  tariff    TariffRule?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model TariffRule {
  id            String      @id @default(cuid())
  vehicleTypeId String      @unique
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id], onDelete: Cascade)
  ratePerKm     Decimal     @db.Decimal(12, 4)
  minimumTotal  Decimal     @db.Decimal(14, 2)
  currency      String      @default("RUB")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Quote {
  id                 String         @id @default(cuid())
  publicCode         String?        @unique
  depotId            String
  depot              Depot          @relation(fields: [depotId], references: [id])
  destinationAddress String?
  destinationLat     Float?
  destinationLng     Float?
  contractReference  String?
  distanceKm         Float
  distanceSource     DistanceSource
  routingMeta        Json?
  inputLines         Json
  breakdown          Json
  total              Decimal        @db.Decimal(14, 2)
  currency           String         @default("RUB")
  createdBy          String?
  createdAt          DateTime       @default(now())

  @@index([createdAt(sort: Desc)])
}
