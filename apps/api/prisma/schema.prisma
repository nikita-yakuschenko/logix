generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DistanceSource {
  ROUTING_API
  MANUAL_OVERRIDE
}

/// Фиксированная точка отгрузки (производство); в MVP — одна запись.
model Depot {
  id        String   @id @default(cuid())
  name      String
  address   String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

/// Тип транспорта (Газель, фура и т.д.).
model VehicleType {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  sortOrder    Int          @default(0)
  tariff       TariffRule?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

/// Тариф по типу ТС: ₽ за км и минимальная сумма по строке расчёта.
model TariffRule {
  id            String      @id @default(cuid())
  vehicleTypeId String      @unique
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id], onDelete: Cascade)
  ratePerKm     Decimal     @db.Decimal(12, 4)
  minimumTotal  Decimal     @db.Decimal(14, 2)
  currency      String      @default("RUB")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

/// Сохранённый расчёт стоимости доставки.
model Quote {
  id                   String          @id @default(cuid())
  depotId              String
  depot                Depot           @relation(fields: [depotId], references: [id])
  destinationAddress   String?
  destinationLat       Float?
  destinationLng       Float?
  /// Номер договора или название объекта (подпись на карте у точки назначения).
  contractReference    String?
  distanceKm           Float
  distanceSource       DistanceSource
  routingMeta          Json?
  inputLines           Json
  breakdown            Json
  total                Decimal         @db.Decimal(14, 2)
  currency             String          @default("RUB")
  /// Кто сформировал расчёт (имя из клиента, без отдельной учётки в MVP).
  createdBy            String?
  createdAt            DateTime        @default(now())

  @@index([createdAt(sort: Desc)])
}
